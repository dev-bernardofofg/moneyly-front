{
  "type": "object",
  "required": [
    "id",
    "userId",
    "type",
    "title",
    "amount",
    "categoryId",
    "frequency",
    "isActive",
    "nextExecution",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "userId": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["income", "expense"] },
    "title": { "type": "string" },
    "amount": { "type": "string" },
    "description": { "type": "string", "nullable": true },
    "categoryId": { "type": "string", "format": "uuid" },
    "frequency": {
      "type": "string",
      "enum": ["daily", "weekly", "monthly", "yearly"]
    },
    "dayOfMonth": {
      "type": "number",
      "minimum": 1,
      "maximum": 31,
      "nullable": true
    },
    "dayOfWeek": {
      "type": "number",
      "minimum": 0,
      "maximum": 6,
      "nullable": true
    },
    "startDate": {
      "type": "string",
      "format": "date-time",
      "nullable": true,
      "description": "Data de início. null = criado imediatamente"
    },
    "totalInstallments": {
      "type": "number",
      "nullable": true,
      "description": "Total de parcelas. null = sem limite"
    },
    "executedInstallments": {
      "type": "number",
      "description": "Quantas parcelas já foram executadas"
    },
    "isActive": { "type": "boolean" },
    "nextExecution": { "type": "string", "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "x-readme-ref-name": "RecurringTransaction"
}
